# ===========================
# Universal Agent Hub .gitignore
# ===========================

# --- Session-specific data ---
logs/
completed/
__pycache__/
artifacts/task*/

# --- File-based Orchestration (deer-flow) ---
orders/*
!orders/.gitkeep
processing/*
!processing/.gitkeep
requests/*
!requests/.gitkeep
!requests/processed/
requests/processed/*
!requests/processed/.gitkeep
state/*
!state/.gitkeep
results/result_*.md
results/request_*.md
results/manual_*.md

# --- Artifacts (keep structure, ignore contents) ---
artifacts/screen/*
artifacts/logs/*
artifacts/drafts/*
artifacts/questions/*
!artifacts/screen/.gitkeep
!artifacts/logs/.gitkeep
!artifacts/drafts/.gitkeep
!artifacts/questions/.gitkeep

# --- Runtime task state (use task_template.md instead) ---
task.md
